# restic-backup.env — copy to /etc/restic/b2.env, fill in, then: sudo chmod 600 /etc/restic/b2.env
# Sourced by restic-backup.sh. Secrets live HERE, never in the script or in git.
#
# Backblaze B2 docs: https://www.backblaze.com/docs/cloud-storage-integrate-restic-with-backblaze-b2
# NOTE: A Synology NAS does NOT qualify for B2's flat $99 "Personal/Computer Backup" plan.
#       These Linux hosts use per-TB B2 Cloud Storage (~$6/TB-month) via this restic repo.

# --- Option A: native B2 backend (simplest) -------------------------------------
# Repo format: b2:<bucket-name>:<path-prefix>
export RESTIC_REPOSITORY="b2:my-homelab-restic:$(hostname -s)"
export B2_ACCOUNT_ID="your_b2_keyID"
export B2_ACCOUNT_KEY="your_b2_applicationKey"

# --- Option B: S3-compatible backend (use INSTEAD of Option A, not both) ---------
# Find your endpoint on the B2 Buckets page (e.g. s3.us-west-002.backblazeb2.com).
# export RESTIC_REPOSITORY="s3:s3.us-west-002.backblazeb2.com/my-homelab-restic"
# export AWS_ACCESS_KEY_ID="your_b2_keyID"
# export AWS_SECRET_ACCESS_KEY="your_b2_applicationKey"

# --- Repository encryption password (file, not inline) --------------------------
# Generate: openssl rand -base64 48 | sudo tee /etc/restic/password >/dev/null && sudo chmod 600 /etc/restic/password
# >>> BACK THIS PASSWORD UP in your password manager AND on paper. Lose it = data unrecoverable. <<<
export RESTIC_PASSWORD_FILE="/etc/restic/password"

# --- Optional overrides ----------------------------------------------------------
# export BACKUP_PATHS="/home /etc /opt /srv"
# export KEEP_DAILY=7
# export KEEP_WEEKLY=4
# export KEEP_MONTHLY=12
# export KEEP_YEARLY=3
