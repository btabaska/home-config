# Optional ntfy alerts from nas-docker-health.sh
# Copy to /volume1/scripts/nas/health.env on the NAS — then chown root:root and
# chmod 600 (the consumer, nas-docker-health.sh, runs as root from a DSM scheduled
# task; nothing else needs to read it). Enforced by verification check
# nas-health-env-perms (fix-23 — this file sat 0777 with a live admin-scoped ntfy
# token until 2026-07-17; that token is revoked and rotated).
#
# NTFY_URL=https://ntfy.tabaska.us
# NTFY_TOPIC=homelab-alerts
# NTFY_TOKEN=                           # if ntfy auth enabled
