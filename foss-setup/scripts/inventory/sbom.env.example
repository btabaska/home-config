# sbom.env — copy to /etc/inventory/sbom.env, fill in, then: sudo chmod 600 /etc/inventory/sbom.env
# Loaded by sbom-nightly.sh AND by sbom-nightly.service (EnvironmentFile=).
# Secrets live HERE, never in the script or in git.

# Base URL of the Dependency-Track API server (your Caddy domain or LAN host:port).
DTRACK_URL=https://deptrack.tabaska.us

# Dependency-Track API key. Create under Administration > Access Management > Teams
# (the "Automation" team) and grant BOM_UPLOAD + PROJECT_CREATION_UPLOAD permissions.
DTRACK_API_KEY=odt_change_this_api_key

# --- Optional overrides ----------------------------------------------------------
# SYFT_VERSION=1.45.1
# GRYPE_VERSION=0.114.0
# ENFORCE_TOOL_PINS=1     # refuse to run if installed scanner != pinned version
# GRYPE_GATE=0            # set 1 to run a local grype scan before each upload
# SCAN_ROOT=/             # filesystem root to SBOM
