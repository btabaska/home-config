# Install as /etc/verification/env (root:btabaska, mode 640). Values come from
# the vault (foss-setup/.handoff-secrets.yaml) — never commit real values here.
# Dedicated ntfy token: docker exec ntfy ntfy token add --label verification admin
NTFY_TOKEN=tk_replace_me
NTFY_URL=http://127.0.0.1:8080/verification

# LLM auto-triage endpoint (verify-04). The authoritative default lives in
# bin/llm-triage.sh + bin/llm_triage.py: llama-swap :9292 / qwen3.6-35b-a3b
# (ai-01, 2026-07-15 — big models moved off ollama :11434, which is now a
# 3-small-model shim that 404s big-model completions). LEAVE THESE UNSET so the
# script default wins — a stale override here silently 404s every triage while
# /v1/models still answers 200 (the H24/M19 quality-gate bug). Only set them to
# deliberately repoint (e.g. LiteLLM :4000, which also needs LLM_API_KEY).
# LLM_BASE_URL=http://cachyos.tailb31641.ts.net:9292/v1
# LLM_MODEL=qwen3.6-35b-a3b
# LLM_API_KEY=            # only when pointing at litellm :4000

# Dead-man ping URLs (self-hosted Healthchecks) — one per scheduled tier. The
# systemd units read these via ${VERIFY_*_PING_URL}; keeping them here (not
# hardcoded in the unit) means the repo units install verbatim (no hand-edit).
# From vault healthchecks.verification_{fast,quick,daily}_mini_ping_url.
VERIFY_FAST_PING_URL=https://health.tabaska.us/ping/replace_me_fast
VERIFY_QUICK_PING_URL=https://health.tabaska.us/ping/replace_me_quick
VERIFY_DAILY_PING_URL=http://192.168.10.2:8001/ping/replace_me_daily

# Plex API — used by media acceptance checks (pinchflat-plex-visible, *-in-plex).
# Token from vault plex.token; URL is the NAS Plex.
PLEX_URL=http://192.168.10.4:32400
PLEX_TOKEN=replace_me_from_vault_plex_token

# Lidarr — used by musicseerr-phantom-requests / lidarr-incomplete-albums.
# Key from vault arr_api_keys.lidarr.
LIDARR_URL=http://192.168.10.4:8686
LIDARR_API_KEY=replace_me_from_vault

# OpenWebUI + LiteLLM virtual key — used by AI-stack consumer checks.
# OWUI_URL is the public wiki-RAG UI; LITELLM_VKEY from vault ai_stack.*.
OWUI_URL=https://ai.tabaska.us
LITELLM_VKEY=replace_me_from_vault

# NAS_SUDO_PASSWORD / SONARR_API_KEY / RADARR_API_KEY / HA_TOKEN etc. are also
# required by various checks — set them here from the vault (values not shown).
