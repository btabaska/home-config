# Agent handoff secrets vault — COPY to .handoff-secrets.yaml, fill in, chmod 600.
# Never commit the filled file. Delete or rotate all values after the handoff sprint.
#
#   cp .handoff-secrets.yaml.example .handoff-secrets.yaml
#   chmod 600 .handoff-secrets.yaml
#
# Give the agent the FILE PATH only — do not paste this into chat.

_meta:
  tailnet: "tailXXXX.ts.net"       # MagicDNS suffix (Settings → DNS in Tailscale admin)
  timezone: "America/New_York"
  notes: ""

# --- Host inventory (handoff-04) -----------------------------------------------
hosts:
  nas:
    lan_ip: "192.168.10.4"
    ssh_user: "btabaska"           # dedicated DSM admin — not built-in admin
    sudo_mode: "password"          # password | nopasswd-snippet | present
  mini:
    lan_ip: "192.168.10.2"
    ssh_user: "btabaska"
    sudo_mode: "password"
  rig:
    lan_ip: "192.168.10.12"
    ssh_user: "btabaska"
    wol_mac: "aa:bb:cc:dd:ee:ff"   # for wake-rig.sh before ssh rig
    sudo_mode: "password"
  seedbox:
    tailscale_name: "betty"        # betty.<tailnet>
    ssh_user: "btabaska"
    home_path: "/home/hd34/btabaska"
  ha:
    lan_ip: "192.168.10.13"
    ssh_user: "root"               # Advanced SSH add-on on HA Green

# --- Running services (handoff-05) — from each app Settings → General ----------
arr_api_keys:
  sonarr: ""
  radarr: ""
  lidarr: ""
  readarr: ""
  prowlarr: ""

plex:
  url: "http://192.168.10.4:32400"
  token: ""

deluge:
  host: "betty"                    # MagicDNS short name
  port: 58846
  password: ""

# --- Backblaze B2 (handoff-06) — scoped app key, one bucket -------------------
backblaze_b2:
  account_id: ""
  application_key: ""
  bucket_hyper_backup: "homelab-nas-tier1"
  bucket_restic: "homelab-restic"
  restic_password_mini: ""         # openssl rand -base64 48
  restic_password_rig: ""

# --- Optional — fill only when starting the related rollout batch --------------
hetzner_storage_box:
  username: ""
  ssh_port: 23

cloudflare:
  api_token: ""                    # Zone.DNS edit only — for Caddy DNS-01

healthchecks:
  restic_mini_ping_url: ""
  borg_ping_url: ""

unifi_protect:
  host: ""
  username: ""
  password: ""

soulseek:
  username: ""
  password: ""
  slskd_web_password: ""
  slskd_api_key: ""

hue:
  bridge_ip: ""

ntfy:
  diun_token: ""                   # ntfy access token for the Diun publisher (topic `diun`)

forgejo:
  admin_user: ""
  admin_password: ""

# --- Sudo handoff (handoff-08) — only if using password mode -------------------
sudo:
  mini_password: ""                # remove from file after sprint
  nas_password: ""
