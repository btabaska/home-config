# Agent handoff secrets vault — COPY to .handoff-secrets.yaml, fill in, chmod 600.
# Never commit the filled file. Delete or rotate all values after the handoff sprint.
#
#   cp .handoff-secrets.yaml.example .handoff-secrets.yaml
#   chmod 600 .handoff-secrets.yaml
#
# Give the agent the FILE PATH only — do not paste this into chat.

_meta:
  tailnet: "tailXXXX.ts.net"       # MagicDNS suffix (Settings → DNS in Tailscale admin)
  timezone: "America/New_York"
  notes: ""

# --- Host inventory (handoff-04) -----------------------------------------------
hosts:
  nas:
    lan_ip: "192.168.10.4"
    ssh_user: "btabaska"           # dedicated DSM admin — not built-in admin
    sudo_mode: "password"          # password | nopasswd-snippet | present
  mini:
    lan_ip: "192.168.10.2"
    ssh_user: "btabaska"
    sudo_mode: "password"
  rig:
    lan_ip: "192.168.10.12"
    ssh_user: "btabaska"
    wol_mac: "aa:bb:cc:dd:ee:ff"   # for wake-rig.sh before ssh rig
    sudo_mode: "password"
  seedbox:
    tailscale_name: "betty"        # betty.<tailnet>
    ssh_user: "btabaska"
    home_path: "/home/hd34/btabaska"
  ha:
    lan_ip: "192.168.10.13"
    ssh_user: "root"               # Advanced SSH add-on on HA Green

# --- Running services (handoff-05) — from each app Settings → General ----------
arr_api_keys:
  sonarr: ""
  radarr: ""
  lidarr: ""
  readarr: ""
  prowlarr: ""

plex:
  url: "http://192.168.10.4:32400"
  token: ""

deluge:
  host: "betty"                    # MagicDNS short name
  port: 58846
  password: ""

# --- Backblaze B2 (handoff-06) — scoped app key, one bucket -------------------
backblaze_b2:
  account_id: ""
  # MASTER key does NOT live in the vault (fix-22 2026-07-17): it can
  # deleteFiles + bypassGovernance, so it stays offline (paper/password
  # manager) and is only used for bucket admin via
  # scripts/backup/b2-apply-bucket-policy.py. Day-to-day = ops key below.
  application_key: "RETIRED-OFFLINE"
  ops_key_id: ""                   # scoped read-only key "b2-ops" (list/read
  ops_key: ""                      # only, no delete/write/bypassGovernance)
  bucket_hyper_backup: "homelab-nas-tier1"
  bucket_restic: "homelab-restic"
  restic_append_only_key_id: ""    # per-host backup key (writeFiles, no delete)
  restic_append_only_key: ""
  restic_password_mini: ""         # openssl rand -base64 48
  restic_password_rig: ""

# --- Optional — fill only when starting the related rollout batch --------------
hetzner_storage_box:
  username: ""
  ssh_port: 23

cloudflare:
  api_token: ""                    # Zone.DNS edit only — for Caddy DNS-01

healthchecks:
  restic_mini_ping_url: ""
  restic_rig_ping_url: ""          # both restic URLs land as RESTIC_HC_URL in /etc/restic/env (fix-42)
  borg_ping_url: ""
  playit_udp_rig_ping_url: ""      # dead-man for playit-udp-guard.timer on rig (fix-34)
  export_manifests_mini_ping_url: ""  # dead-man for export-manifests.timer on mini (fix-41)

unifi_protect:
  host: ""
  username: ""
  password: ""

soulseek:
  username: ""
  password: ""
  slskd_web_password: ""
  slskd_api_key: ""

ai_stack:                          # LiteLLM per-client virtual keys (ai-01, fix-29)
  litellm_opencode_key: ""
  litellm_openwebui_key: ""
  litellm_ops_agent_key: ""
  openwebui_rag_sync_api_key: ""
  litellm_verify_key: ""           # fix-29 / M57: least-priv (utility model only)
                                   # consumer-end probe for rig-litellm-consumer-e2e;
                                   # lives on rig ~/.config/fleet-mcp/env LITELLM_VERIFY_KEY

hue:
  bridge_ip: ""

ntfy:
  diun_token: ""                   # ntfy access token for the Diun publisher (topic `diun`)

forgejo:
  admin_user: ""
  admin_password: ""
  # Full live /opt/stacks/forgejo/.env capture (fix-41): the forge is the deploy
  # control plane, so its exact env — FORGEJO_DB_PASSWORD included — must be
  # rebuildable from repo mirror (configs/docker-stack/stacks/forgejo) + vault.
  env:
    FORGEJO_UID: ""
    FORGEJO_GID: ""
    FORGEJO_DB_PASSWORD: ""
    FORGEJO_DOMAIN: ""
    FORGEJO_ROOT_URL: ""
    FORGEJO_SSH_PORT: ""
    FORGEJO_DISABLE_REGISTRATION: ""
    FORGEJO_REQUIRE_SIGNIN: ""

# --- Sudo handoff (handoff-08) — only if using password mode -------------------
sudo:
  mini_password: ""                # remove from file after sprint
  nas_password: ""
