# Example automations.yaml entries for the FOSS homelab smart-home stack.
# These tie together Hue, Nest, Midea, and the local Assist voice pipeline.
# Replace entity_ids (sensor.*, climate.*, light.*) with your real ones from
# Developer Tools > States. Append to your existing automations.yaml.
#
# Docs: https://www.home-assistant.io/docs/automation/

# 1) Dehumidify when humidity is high (local Midea via midea_ac_lan).
- id: midea_dehumidify_high_humidity
  alias: "Dehumidifier on when humidity > 60%"
  trigger:
    - platform: numeric_state
      entity_id: sensor.basement_humidity
      above: 60
  condition: []
  action:
    - action: humidifier.turn_on
      target:
        entity_id: humidifier.midea_dehumidifier
  mode: single

# 2) Pre-cool with the Midea AC when the Nest reports the house is warm and nobody
#    has manually overridden. Demonstrates Nest (cloud) + Midea (local) together.
- id: precool_ac_when_warm
  alias: "Pre-cool AC when Nest temp high"
  trigger:
    - platform: numeric_state
      entity_id: sensor.nest_thermostat_temperature
      above: 26
  condition:
    - condition: time
      after: "14:00:00"
      before: "20:00:00"
  action:
    - action: climate.set_temperature
      target:
        entity_id: climate.midea_ac_living_room
      data:
        temperature: 23
        hvac_mode: cool
  mode: single

# 3) Hue scene on local voice intent / motion. Hue is fully local via the bridge.
- id: hue_evening_scene
  alias: "Evening Hue scene at sunset"
  trigger:
    - platform: sun
      event: sunset
      offset: "-00:15:00"
  action:
    - action: light.turn_on
      target:
        entity_id: light.living_room
      data:
        brightness_pct: 60
        color_temp_kelvin: 2700
  mode: single

# 4) Spoken confirmation through the local Assist (Piper TTS) pipeline.
#    Uses the Piper TTS engine added via the Whisper/Piper add-ons.
- id: voice_announce_ac_on
  alias: "Announce when AC turns on"
  trigger:
    - platform: state
      entity_id: climate.midea_ac_living_room
      to: "cool"
  action:
    - action: tts.speak
      target:
        entity_id: tts.piper
      data:
        cache: true
        media_player_entity_id: media_player.living_room_speaker
        message: "Cooling the living room now."
  mode: single
