# RomM secrets — copy to .env on the host and fill from the vault.
# .env is gitignored; never commit real values.
TZ=America/New_York

# MariaDB (vault: romm.db_root_password / romm.db_password)
ROMM_DB_ROOT_PASSWD=
ROMM_DB_PASSWD=

# Session signing key (vault: romm.auth_secret_key; `openssl rand -hex 32`)
ROMM_AUTH_SECRET_KEY=

# IGDB / Twitch app (vault: igdb.client_id / igdb.client_secret)
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# RetroAchievements web API key (vault: romm.retroachievements_api_key)
# One key for the whole instance; each user then sets their RA username in
# their RomM profile to sync earned achievements. HowLongToBeat (HLTB_API_ENABLED
# in compose) needs no key.
RETROACHIEVEMENTS_API_KEY=
