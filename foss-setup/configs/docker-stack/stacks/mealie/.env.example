# Mealie — copy to .env and edit. Docs: https://docs.mealie.io/documentation/getting-started/installation/backend-config/
# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=America/New_York

# Run as your host user so ./data ownership stays sane.
PUID=1000
PGID=1000

# Public URL Mealie is served at (set to your Caddy domain, e.g. https://recipes.example.com).
MEALIE_BASE_URL=http://localhost:9000

# Required: long random secret used to sign sessions/tokens. Generate one:
#   openssl rand -hex 32
MEALIE_SECRET=change_this_long_random_secret
