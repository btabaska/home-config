# MeTube — copy to .env and edit. Docs: https://github.com/alexta69/metube
# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=America/New_York

# Where one-off downloads land. NAS youtube share is CIFS-mounted at
# /mnt/nas-youtube (see /etc/fstab on mini).
METUBE_DOWNLOADS=/mnt/nas-youtube/metube
