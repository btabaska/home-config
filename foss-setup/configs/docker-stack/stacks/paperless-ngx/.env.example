# Paperless-ngx — copy to .env and edit. Docs: https://docs.paperless-ngx.com/configuration/
# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=America/New_York

# Run the app as your host user so consumed/imported files keep sane ownership.
PUID=1000
PGID=1000

# Required: a long random secret used to sign sessions/tokens. Generate one:
#   openssl rand -base64 48
PAPERLESS_SECRET_KEY=change_this_long_random_secret

# Postgres password for the "broker" DB. Generate one: openssl rand -base64 24
PAPERLESS_DBPASS=change_this_strong_db_password

# OCR language(s), Tesseract codes. Multiple: "eng+deu". See:
#   https://docs.paperless-ngx.com/configuration/#ocr
PAPERLESS_OCR_LANGUAGE=eng

# Public URL Paperless is served at (set to your Caddy domain, e.g. https://paperless.example.com).
# Used for correct links and CSRF/host checks.
PAPERLESS_URL=http://localhost:8000

# First-run admin account name (created on first boot only). Set the password
# interactively instead (`docker compose run --rm webserver createsuperuser`) —
# the live stack keeps no PAPERLESS_ADMIN_PASSWORD in its .env, and carrying a
# first-boot-only password here just drifts from the running deployment.
PAPERLESS_ADMIN_USER=admin
