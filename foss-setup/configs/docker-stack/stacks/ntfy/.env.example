# ntfy — copy to .env and edit. Docs: https://docs.ntfy.sh/config/
# Public URL (must match the Caddy domain; used for topic URLs and Web Push)
NTFY_BASE_URL=https://ntfy.example.com

# Lock the server down: deny anonymous access, then create users/tokens with the CLI:
#   docker compose exec ntfy ntfy user add --role=admin admin
#   docker compose exec ntfy ntfy token add admin       # token for Diun/scripts
NTFY_AUTH_DEFAULT_ACCESS=deny-all

# UID/GID owning ./cache and ./lib (run `id`). chown those dirs to match.
PUID=1000
PGID=1000

TZ=America/New_York
