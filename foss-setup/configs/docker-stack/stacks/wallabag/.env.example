# Wallabag — copy to .env and edit. Docs: https://doc.wallabag.org/admin/parameters/
# Generate strong secrets, e.g.:  openssl rand -base64 24   /   openssl rand -hex 32

# --- Database (MariaDB) ---
# Root password is used by wallabag on first boot to create the DB / run migrations.
WALLABAG_DB_ROOT_PASSWORD=change_this_strong_root_password
# Application DB user password (user 'wallabag', db 'wallabag').
WALLABAG_DB_PASSWORD=change_this_strong_db_password

# --- App ---
# Long random app secret (CSRF / token signing). e.g. openssl rand -hex 32
WALLABAG_SECRET=change_this_to_a_long_random_hex_string
# Run DB migrations on container start. true on first boot; you may set false after.
WALLABAG_POPULATE_DATABASE=true

# Public URL Wallabag is served at (used for links + the KOReader plugin server_url).
# Set to your Caddy domain in production, e.g. https://wallabag.example.com
WALLABAG_DOMAIN_NAME=https://wallabag.example.com
WALLABAG_SERVER_NAME=My Wallabag

# --- Mail (optional) ---
# Default points at a local sink; set real SMTP if you want password-reset emails.
WALLABAG_MAILER_DSN=smtp://127.0.0.1
WALLABAG_FROM_EMAIL=wallabag@example.com

# --- First login ---
# Default credentials on a fresh install are  wallabag / wallabag  — log in and
# change the password immediately (User management), then create an API client
# under Settings -> API clients management for the KOReader plugin.
