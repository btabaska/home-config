# LiteLLM — copy to .env and edit. Docs: https://docs.litellm.ai/docs/proxy/configs
# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=America/New_York

# Master key clients send as the OpenAI API key. MUST start with "sk-". Generate one:
#   echo "sk-$(openssl rand -hex 24)"
LITELLM_MASTER_KEY=sk-change_this_long_random_key
