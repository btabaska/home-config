# LiteLLM — copy to .env and edit. Docs: https://docs.litellm.ai/docs/proxy/configs
# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=America/New_York

# Master key clients send as the OpenAI API key. MUST start with "sk-". Generate one:
#   echo "sk-$(openssl rand -hex 24)"
LITELLM_MASTER_KEY=sk-change_this_long_random_key

# REMINDER (not a LiteLLM var): for the Mac-mini Ollama fallback to be reachable
# via host.docker.internal, the HOST's Ollama must listen on all interfaces.
# Set OLLAMA_HOST=0.0.0.0 in the Ollama service environment on the Mac mini
# (e.g. systemd drop-in or launchd) and allow TCP 11434 through its firewall.
