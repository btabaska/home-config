# Tdarr — copy to .env and edit. Docs: https://docs.tdarr.io/
# UID/GID that owns the bind-mounted dirs (run `id` to find yours)
PUID=1000
PGID=1000

# Timezone
TZ=America/New_York

# Absolute path to the media library Tdarr scans/transcodes (e.g. an NAS mount).
MEDIA_FOLDER=/mnt/nas/media

# Fast LOCAL scratch for in-progress transcodes — do NOT point this at the NAS.
TRANSCODE_CACHE=./transcode_cache
