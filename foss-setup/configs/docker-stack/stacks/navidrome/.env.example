# Navidrome — copy to .env and edit. Docs: https://www.navidrome.org/docs/usage/configuration-options/
# UID/GID that owns ./data (run `id` to find yours)
PUID=1000
PGID=1000

# Absolute path to your music library (mounted read-only). On the NAS three-volume layout:
# mount /volume1/music (SMB/NFS) or use the host path directly if Navidrome runs on the NAS.
MUSIC_FOLDER=/mnt/nas/music

# Timezone
TZ=America/New_York

# Set if serving under a subpath behind the proxy; leave empty for a dedicated subdomain.
ND_BASEURL=

# Nightly SQLite backups (ND_BACKUP_SCHEDULE is cron syntax, container-local
# time). Without these a rebuild silently loses play counts/favorites history
# on the next DB corruption — keep them set (armed 2026-07-18, fix-37).
ND_BACKUP_SCHEDULE=0 2 * * *
ND_BACKUP_COUNT=7

# Opt out of anonymous usage telemetry.
ND_ENABLEINSIGHTSCOLLECTOR=false
