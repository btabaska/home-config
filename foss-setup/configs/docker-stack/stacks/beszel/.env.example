# Beszel — copy to .env and edit. Docs: https://beszel.dev/guide/agent-installation
# Public URL of the hub (set to your Caddy domain so links/notifications work)
BESZEL_APP_URL=https://status.example.com

# Generated by the hub the first time you click "Add System". Boot the hub first,
# create your admin account, add this host, then paste the values here and restart.
BESZEL_AGENT_TOKEN=
BESZEL_AGENT_KEY=
