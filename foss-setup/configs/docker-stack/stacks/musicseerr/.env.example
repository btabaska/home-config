# MusicSeerr — copy to .env and edit. Docs: https://musicseerr.com/docs/getting-started/
# UID/GID that owns ./config and ./cache (run `id` on the Mac mini)
PUID=1000
PGID=1000

# Timezone
TZ=America/New_York

# Read-only NFS mount of the NAS music library (same path as Navidrome — docker-05).
# Enables local file playback in MusicSeerr Settings → Local Files → /music.
# Leave unset in compose only if you rely on Plex/Navidrome playback exclusively.
MUSIC_FOLDER=/mnt/nas/music

# Lidarr connection (music requests are forwarded to Lidarr). API key from
# Lidarr → Settings → General → Security. Without it MusicSeerr cannot submit
# or track any request — the UI loads fine, so probe the Lidarr link end-to-end.
LIDARR_API_KEY=
