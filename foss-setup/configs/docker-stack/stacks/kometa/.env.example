# Kometa — copy to .env and edit. Docs: https://kometa.wiki/
# UID/GID that owns ./config (run `id` to find yours)
PUID=1000
PGID=1000

# Timezone
TZ=America/New_York

# Daily scheduled run time (24h HH:MM); comma-separate for multiple runs.
KOMETA_TIME=05:00

# Force an immediate run when the container starts (True/False).
# Leave False for normal scheduled operation.
KOMETA_RUN=False
