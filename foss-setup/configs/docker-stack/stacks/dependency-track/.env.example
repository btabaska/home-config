# Dependency-Track — copy to .env and edit. Docs: https://docs.dependencytrack.org/
# Generate a strong DB password, e.g.:  openssl rand -base64 24

# PostgreSQL credentials (shared by apiserver + postgres). User defaults to 'dtrack'.
DTRACK_DB_USER=dtrack
DTRACK_DB_PASSWORD=change_this_strong_db_password

# Public URL the frontend uses to reach the API server (your Caddy domain).
DTRACK_API_BASE_URL=https://deptrack.tabaska.us

# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=America/New_York
