# Homepage — copy to .env and edit. Docs: https://gethomepage.dev/configs/
# UID/GID that owns ./config (run `id` to find yours)
PUID=1000
PGID=1000

# Timezone
TZ=America/New_York

# Comma-separated host:port (and proxy subdomain) you browse Homepage from.
# Required since v1.x; "*" disables the check (not recommended). e.g.:
#   home.example.com,homepage.example.com,192.168.1.10:3010,localhost:3010
HOMEPAGE_ALLOWED_HOSTS=localhost:3010

# --- Service-widget API keys (referenced as {{HOMEPAGE_VAR_*}} in services.yaml) ---
# Fill these in to light up live widgets; leave blank to show a plain link tile.
HOMEPAGE_VAR_SONARR_KEY=
HOMEPAGE_VAR_RADARR_KEY=
HOMEPAGE_VAR_LIDARR_KEY=
HOMEPAGE_VAR_PROWLARR_KEY=
HOMEPAGE_VAR_PLEX_TOKEN=
HOMEPAGE_VAR_TAUTULLI_KEY=
HOMEPAGE_VAR_QBITTORRENT_USER=
HOMEPAGE_VAR_QBITTORRENT_PASS=
HOMEPAGE_VAR_IMMICH_KEY=
HOMEPAGE_VAR_SEERR_KEY=
HOMEPAGE_VAR_ADGUARD_USER=
HOMEPAGE_VAR_ADGUARD_PASS=
HOMEPAGE_VAR_UPTIMEKUMA_SLUG=
HOMEPAGE_VAR_DEPTRACK_KEY=
