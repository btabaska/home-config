# Homepage — copy to .env and edit. Docs: https://gethomepage.dev/configs/
# UID/GID that owns ./config (run `id` to find yours)
PUID=1000
PGID=1000

# Timezone
TZ=America/New_York

# MUST EDIT: comma-separated host:port (and proxy subdomain) you browse Homepage
# from. Since v1.0 this is a REQUIRED, EXACT-MATCH allowlist — if the value you
# type in the browser's address bar (LAN IP:port and/or your Caddy domain) is not
# listed here verbatim, Homepage returns a "Host validation failed" error and the
# page won't load. Add every host you'll use. "*" disables the check (insecure;
# not recommended). e.g.:
#   home.example.com,homepage.example.com,192.168.1.10:3010,localhost:3010
HOMEPAGE_ALLOWED_HOSTS=localhost:3010

# --- Service-widget API keys (referenced as {{HOMEPAGE_VAR_*}} in services.yaml) ---
# Fill these in to light up live widgets; leave blank to show a plain link tile.
HOMEPAGE_VAR_SONARR_KEY=
HOMEPAGE_VAR_RADARR_KEY=
HOMEPAGE_VAR_LIDARR_KEY=
HOMEPAGE_VAR_READARR_KEY=
HOMEPAGE_VAR_BOOKSHELF_KEY=
HOMEPAGE_VAR_PROWLARR_KEY=
HOMEPAGE_VAR_PLEX_TOKEN=
HOMEPAGE_VAR_JELLYFIN_KEY=
HOMEPAGE_VAR_TAUTULLI_KEY=
HOMEPAGE_VAR_QBITTORRENT_USER=
HOMEPAGE_VAR_QBITTORRENT_PASS=
HOMEPAGE_VAR_IMMICH_KEY=
HOMEPAGE_VAR_SEERR_KEY=
HOMEPAGE_VAR_ADGUARD_USER=
HOMEPAGE_VAR_ADGUARD_PASS=
HOMEPAGE_VAR_HA_TOKEN=
HOMEPAGE_VAR_UPTIMEKUMA_SLUG=
HOMEPAGE_VAR_DEPTRACK_KEY=
# Palworld REST API (8212) basic-auth password = vault palworld.admin_password
HOMEPAGE_VAR_PALWORLD_ADMIN=

# --- home-06 wave-2 widgets (existing services, one credential each) ---
# Direct vault values: healthchecks.api_key, miniflux.api_key, deluge.password,
# soulseek.slskd_api_key, calibre-web.username/password, navidrome.username/password.
# Minted/derived (stored under vault homepage_widgets.*): paperless/mealie/forgejo
# tokens, stash API key, navidrome salt+token (token = md5(password + salt)).
HOMEPAGE_VAR_HEALTHCHECKS_KEY=
HOMEPAGE_VAR_PAPERLESS_KEY=
HOMEPAGE_VAR_MEALIE_KEY=
HOMEPAGE_VAR_MINIFLUX_KEY=
HOMEPAGE_VAR_CALIBREWEB_USER=
HOMEPAGE_VAR_CALIBREWEB_PASS=
HOMEPAGE_VAR_STASH_KEY=
HOMEPAGE_VAR_DELUGE_PASS=
HOMEPAGE_VAR_SLSKD_KEY=
HOMEPAGE_VAR_FORGEJO_KEY=
HOMEPAGE_VAR_SYNCTHING_HUB_KEY=  # NAS hub Syncthing REST API key (config.xml <apikey>); foss-03
HOMEPAGE_VAR_NAVIDROME_USER=
HOMEPAGE_VAR_NAVIDROME_SALT=
HOMEPAGE_VAR_NAVIDROME_TOKEN=

# --- home-07 Fleet host tiles (beszel widget, superuser account required) ---
# Values = vault beszel.admin_user / beszel.admin_password (the hub's superuser).
HOMEPAGE_VAR_BESZEL_USER=
HOMEPAGE_VAR_BESZEL_PASS=

# --- home-08 Calendar tile: published Proton Calendar .ics feed for the agenda ---
# Value = vault homepage_widgets.proton_calendar_ics_url (a private share link).
# The *arr release side of the Calendar reuses the existing Sonarr/Radarr/Lidarr
# widget keys (no new secret).
HOMEPAGE_VAR_PROTON_CAL_ICS=

# home-08 UniFi Network tile: dedicated LOCAL read-only Network account (View Only
# role) on the UDM/Dream Wall (https://192.168.10.1) — the unifi_protect account 403s
# on Network auth so it cannot be reused. Values = vault unifi_network.username/password.
HOMEPAGE_VAR_UNIFI_USER=
HOMEPAGE_VAR_UNIFI_PASS=
