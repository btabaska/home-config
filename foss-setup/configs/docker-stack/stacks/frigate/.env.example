# Frigate — copy to .env and edit. Docs: https://docs.frigate.video/configuration/
# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=America/New_York

# Password substituted into go2rtc/RTSP restream + used by the auth UI. Generate one:
#   openssl rand -base64 24
FRIGATE_RTSP_PASSWORD=change_this_strong_password

# Where recordings/snapshots are written. Point at a large disk or the NAS media share.
# Defaults to ./media next to this compose file if unset.
FRIGATE_MEDIA=./media
