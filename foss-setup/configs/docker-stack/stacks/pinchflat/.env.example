# Pinchflat — copy to .env and edit. Docs: https://github.com/kieraneglin/pinchflat
# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=America/New_York

# Where downloaded videos land. Point at your Plex "YouTube" library path so Plex
# indexes them, e.g. /volume1/youtube.
PINCHFLAT_DOWNLOADS=/volume1/youtube

# Optional: serve under a sub-path behind a reverse proxy (uncomment in compose too).
# PINCHFLAT_BASE_PATH=/pinchflat
