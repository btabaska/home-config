# Forgejo — environment template. Copy to `.env` and fill in. NEVER commit `.env`.
#   cp .env.example .env && ${EDITOR:-nano} .env
#
# Generate strong secrets:
#   openssl rand -base64 32

# --- Host user mapping --------------------------------------------------------
# Run `id -u` / `id -g` on the Ubuntu host and paste the values so the bind-mounted
# ./data/forgejo directory ends up owned correctly.
FORGEJO_UID=1000
FORGEJO_GID=1000

# --- Database -----------------------------------------------------------------
# Used by BOTH the forgejo and db services; they must match. No quotes, no spaces.
FORGEJO_DB_PASSWORD=change-me-openssl-rand-base64-32

# --- Server / URLs ------------------------------------------------------------
# DOMAIN is the hostname users browse to; ROOT_URL is the full external URL
# (set this to your Caddy/Tailscale hostname in production, with a trailing slash).
FORGEJO_DOMAIN=git.local
FORGEJO_ROOT_URL=http://localhost:3000/

# Host port for git-over-SSH (host 22 is taken by the box's own sshd).
FORGEJO_SSH_PORT=2222

# --- Access control -----------------------------------------------------------
# Keep registration disabled for a single-user homelab. Create your admin account
# on first run, then these stay locked. Set REQUIRE_SIGNIN=false only if you want
# anonymous read of public repos.
FORGEJO_DISABLE_REGISTRATION=true
FORGEJO_REQUIRE_SIGNIN=true
