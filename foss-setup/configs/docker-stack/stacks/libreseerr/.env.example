# Libreseerr — copy to .env on the Mac mini (/opt/stacks/libreseerr)
TZ=America/New_York
# Stable session key — generate once: openssl rand -hex 32
SECRET_KEY=
# fix-48 B12: ntfy publish token for terminal request-failure notifications
# (vault ntfy.libreseerr_token; mint: docker exec ntfy ntfy token add --label libreseerr admin)
NTFY_TOKEN=
