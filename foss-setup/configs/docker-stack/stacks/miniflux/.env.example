# Miniflux — copy to .env and edit. Docs: https://miniflux.app/docs/configuration.html
# Generate a strong DB password, e.g.:  openssl rand -base64 24
MINIFLUX_DB_PASSWORD=change_this_strong_db_password

# First-run admin account (remove CREATE_ADMIN block from compose after first login)
MINIFLUX_ADMIN_USERNAME=admin
MINIFLUX_ADMIN_PASSWORD=change_this_admin_password

# Public URL Miniflux is served at (used for feed/API links). Set to your Caddy domain.
MINIFLUX_BASE_URL=https://rss.example.com
