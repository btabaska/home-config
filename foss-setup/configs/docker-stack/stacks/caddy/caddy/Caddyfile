# Self-hosted Git forge (control repo). Git-over-SSH stays on host port 2222.
git.{$DOMAIN} {
	import local_tls
	reverse_proxy forgejo:3000
}

# Password manager (Vaultwarden — Bitwarden-compatible). Needs websockets for
# live sync; modern Caddy proxies them automatically, no extra config needed.
vault.{$DOMAIN} {
	import local_tls
	reverse_proxy vaultwarden:80
}

# Rig AI stack (CachyOS — on-demand). HTTPS terminates on Mac mini Caddy, not the rig.
# Set RIG_IP in .env (default homelab: 192.168.10.12).

# Open WebUI chat UI
ai.{$DOMAIN} {
	import local_tls
	reverse_proxy {$RIG_IP}:3000
}

# LiteLLM gateway (OpenAI-compatible API + /ui admin)
llm.{$DOMAIN} {
	import local_tls
	reverse_proxy {$RIG_IP}:4000
}

# Ollama native API (direct /v1 for OpenCode, Obsidian, scripts)
ollama.{$DOMAIN} {
	import local_tls
	reverse_proxy {$RIG_IP}:11434
}

# mcpo tool bridge (OpenAPI docs at /docs)
mcpo.{$DOMAIN} {
	import local_tls
	reverse_proxy {$RIG_IP}:8000
}

# Sunshine game-stream host UI (rig — HTTPS with a self-signed cert on :47990).
# On-demand like the rest of the rig stack; expect 502 while the rig sleeps.
sunshine.{$DOMAIN} {
	import local_tls
	reverse_proxy https://{$RIG_IP}:47990 {
		transport http {
			tls_insecure_skip_verify
		}
	}
}

# Backup dead-man's-switch
health.{$DOMAIN} {
	import local_tls
	reverse_proxy healthchecks:8000
}

# SBOM / vulnerability dashboard (runs on NAS — frontend :9010, API :9011)
deptrack.{$DOMAIN} {
	import local_tls
	handle /api/* {
		reverse_proxy {$NAS_IP}:9011
	}
	reverse_proxy {$NAS_IP}:9010
}

