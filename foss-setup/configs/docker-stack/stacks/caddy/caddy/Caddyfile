# ---------------------------------------------------------------------------
# Smart home
# ---------------------------------------------------------------------------

# Home Assistant (dedicated host — HA_IP in .env).
# NOTE: HA will answer 400 "Bad Request" through this proxy until its
# `http.use_x_forwarded_for` + `trusted_proxies` include the mini's Docker
# networks — configured in run-5.
ha.{$DOMAIN} {
	import local_tls
	reverse_proxy {$HA_IP}:8123
}

# ---------------------------------------------------------------------------
# Wiki — static site built into /opt/stacks/wiki/site on the host, mounted
# read-only at /srv/wiki (see compose.yaml). Serves 404 until the wiki build
# lands; that's expected.
# ---------------------------------------------------------------------------

wiki.{$DOMAIN} {
	import local_tls
	root * /srv/wiki
	file_server
}

# ---------------------------------------------------------------------------
# NOTE on host placement: the upstreams above use container names, which only
# resolve for services that share this Caddy host's `edge` network (i.e. run on
# the Mac mini). If you offload a heavy service to the NAS (see the plan's host
# table — Frigate, Paperless, Dependency-Track, Tdarr are good candidates),
# change that one block to the NAS instead, e.g.:
#     reverse_proxy {$NAS_IP}:8000      # paperless on the NAS
# and set NAS_IP in .env. Everything else stays container-name routed.
# ---------------------------------------------------------------------------
