# Caddyfile — reverse proxy for the Mac mini docker stack.
# Docs: https://caddyserver.com/docs/caddyfile
#
# Each service is reachable by its container name on the shared `edge` network.
# Replace example.com with your domain. Subdomains assume a wildcard DNS record
# (*.example.com -> Mac mini LAN IP) or individual A/AAAA records.

{
	email {$ACME_EMAIL}
	# Optional: smaller log, and enable HTTP/3 is on by default in Caddy 2.11.
}

# ---------------------------------------------------------------------------
# Reusable TLS snippet. Choose ONE approach per site below.
#
# (A) DNS-01 wildcard via Cloudflare (recommended for internal-only services).
#     Requires the custom image built from ./Dockerfile and a CLOUDFLARE_API_TOKEN.
(cloudflare_tls) {
	tls {
		dns cloudflare {$CLOUDFLARE_API_TOKEN}
		resolvers 1.1.1.1
	}
}
#
# (B) Caddy internal CA (no public DNS needed; clients must trust Caddy's root).
(local_tls) {
	tls internal
}
# ---------------------------------------------------------------------------

# Media request portals (movies/TV + music)
seerr.{$DOMAIN} {
	import cloudflare_tls
	reverse_proxy seerr:5055
}

musicseerr.{$DOMAIN} {
	import cloudflare_tls
	reverse_proxy musicseerr:8688
}

