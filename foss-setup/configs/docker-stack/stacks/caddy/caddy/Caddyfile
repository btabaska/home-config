# Cloudflare-challenge solver for Prowlarr indexers (NAS — :8191; API, no real UI)
flaresolverr.{$DOMAIN} {
	import local_tls
	reverse_proxy {$NAS_IP}:8191
}

# Adult media organizer (NAS — :9999; LAN/Tailscale only)
stash.{$DOMAIN} {
	import local_tls
	reverse_proxy {$NAS_IP}:9999 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Port {server_port}
	}
}

