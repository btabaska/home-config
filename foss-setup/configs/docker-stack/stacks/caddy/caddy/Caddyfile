# Adult media organizer (NAS — :9999; LAN/Tailscale only)
stash.{$DOMAIN} {
	import local_tls
	reverse_proxy {$NAS_IP}:9999 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}

