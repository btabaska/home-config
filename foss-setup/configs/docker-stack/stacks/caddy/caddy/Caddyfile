# Self-hosted Git forge (control repo). Git-over-SSH stays on host port 2222.
git.{$DOMAIN} {
	import local_tls
	reverse_proxy forgejo:3000
}

# Password manager (Vaultwarden — Bitwarden-compatible). Needs websockets for
# live sync; modern Caddy proxies them automatically, no extra config needed.
vault.{$DOMAIN} {
	import local_tls
	# /admin only from LAN + tailnet (sec audit 2026-07-08); page was public before
	@adminExternal {
		path /admin*
		not remote_ip private_ranges 100.64.0.0/10
	}
	respond @adminExternal 403
	reverse_proxy vaultwarden:80
}

# Rig AI stack (CachyOS — on-demand). HTTPS terminates on Mac mini Caddy, not the rig.
# Set RIG_IP in .env (default homelab: 192.168.10.12).

# Open WebUI chat UI
