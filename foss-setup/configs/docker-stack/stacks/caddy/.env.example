# Caddy — copy to .env and edit. Docs: https://caddyserver.com/docs/automatic-https
# Base domain; services are served at <name>.${DOMAIN}
DOMAIN=example.com

# Email for Let's Encrypt / ZeroSSL ACME account
[email protected]

# Cloudflare API token (Zone:DNS:Edit on your zone) for DNS-01 wildcard certs.
# Only needed if using the (cloudflare_tls) snippet + the custom-built image.
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Optional: LAN IP of the NAS, for fronting services you offload there (e.g.
# Frigate/Paperless/Dependency-Track/Tdarr, *arr stack, Plex). Referenced by
# `{$NAS_IP}` in the Caddyfile. Leave blank if every fronted service runs on
# the Mac mini.
NAS_IP=

# Betty seedbox Tailscale IP (Deluge :8112, slskd :5030). Find with:
#   ssh mini 'tailscale status | grep seedbox'
SEEDBOX_IP=

# Mac mini LAN IP for stacks that bind host ports but are not on the `edge`
# network (e.g. MeTube at :8081). Default for this homelab: 192.168.10.2
HOST_IP=

# CachyOS rig LAN IP — Ollama, Open WebUI, LiteLLM, mcpo (ai/llm/ollama/mcpo subdomains).
# Default for this homelab: 192.168.10.12
RIG_IP=
