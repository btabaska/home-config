# Caddy — copy to .env and edit. Docs: https://caddyserver.com/docs/automatic-https
# Base domain; services are served at <name>.${DOMAIN}
DOMAIN=example.com

# Email for Let's Encrypt / ZeroSSL ACME account. (NB: an earlier revision of
# this line was pasted from a web page whose email-obfuscation script replaced
# the whole assignment with "[email protected]" — keep the ACME_EMAIL= key.)
ACME_EMAIL=admin@example.com

# Cloudflare API token (Zone:DNS:Edit on your zone) for DNS-01 wildcard certs.
# Only needed if using the (cloudflare_tls) snippet + the custom-built image.
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Optional: LAN IP of the NAS, for fronting services you offload there (e.g.
# Frigate/Paperless/Dependency-Track/Tdarr, *arr stack, Plex). Referenced by
# `{$NAS_IP}` in the Caddyfile. Leave blank if every fronted service runs on
# the Mac mini.
NAS_IP=

# Betty seedbox Tailscale IP (Deluge :8112, slskd :5030). Find with:
#   ssh mini 'tailscale status | grep seedbox'
SEEDBOX_IP=

# Home Assistant host LAN IP (ha.${DOMAIN} → :8123). Default homelab: 192.168.10.50
HA_IP=

# Mac mini LAN IP for stacks that bind host ports but are not on the `edge`
# network (e.g. MeTube at :8081). Default for this homelab: 192.168.10.2
HOST_IP=

# LAN IP of the rig (CachyOS AI + gaming host) for ai/llm/llamaswap/ollama/
# lumiverse/marinara vhosts. Default for this homelab: 192.168.10.12
RIG_IP=

# Basic Auth for marinara.tabaska.us. Marinara-Engine's own auth is ineffective
# behind Docker's userland-proxy (it only ever sees a trusted private/Docker IP),
# so Caddy gates it. Generate the hash with:  docker exec caddy caddy hash-password
MARINARA_BASICAUTH_USER=marinara
MARINARA_BASICAUTH_HASH=
