# Healthchecks — copy to .env and edit. Docs: https://healthchecks.io/docs/self_hosted_configuration/
# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=America/New_York

# Required: long random secret. Generate one: openssl rand -base64 48
HC_SECRET_KEY=change_this_long_random_secret

# Public base URL used to build ping URLs (set to your Caddy domain, e.g. https://health.example.com).
HC_SITE_ROOT=http://localhost:8001

# Comma-separated hostnames Django will serve (your domain + LAN IP). "*" allows all.
HC_ALLOWED_HOSTS=*

# From-address used on notification emails.
HC_DEFAULT_FROM_EMAIL=healthchecks@example.com

# Postgres password for the bundled DB. Generate one: openssl rand -base64 24
HC_DB_PASSWORD=change_this_strong_db_password

# First-run superuser (login to the web UI). Remove after first login if desired.
HC_SUPERUSER_EMAIL=admin@example.com
HC_SUPERUSER_PASSWORD=change_this_admin_password
