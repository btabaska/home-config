# journaling stack env — copy to .env and fill. KEY NAMES + non-secret defaults only.
# LAN/tailnet only. No cloud, no telemetry. See docs/journaling-stack-plan.md.

# Timezone (all three services)
TZ=America/New_York

# n8n reverse-proxy identity (fronted by Caddy). Editor + webhooks use this host.
N8N_HOST=n8n.tabaska.us
N8N_WEBHOOK_URL=https://n8n.tabaska.us/

# --- Inference (rig llama-swap, OpenAI-compatible; NOT raw Ollama :11434) --------
# Consumed by the journal-analyze workflow (journal-03), not by compose.
RIG_IP=192.168.10.12
LLM_BASE_URL=http://192.168.10.12:9292/v1
LLM_MODEL=dolphin-venice-24b
# One-line creative-but-VRAM-tight alt (OOMs while gaming): deckard-heretic
LLM_TEMP=0.35

# --- Server-side dictation (faster-whisper/speaches, CPU, internal only) ----------
# Consumed by the journal-analyze audio branch (journal-04), not by compose logic.
# Container listens on 8000 (host-published as 8010); n8n reaches it by name on the
# journaling network. The workflow nodes default to these exact values, so leaving
# them unset still works — they exist for a one-line model/endpoint swap.
WHISPER_BASE_URL=http://faster-whisper:8000/v1
WHISPER_MODEL=Systran/faster-whisper-small

# --- Secrets (minted in journal-02; vault journaling.* — MERGE never blind-assign) -
# Memos never-expiring Personal Access Token (memos_pat_...) for n8n write-back
# (create-comment, journal-03). Value lives in the live .env (chmod 600) and
# canonically at vault journaling.memos.api_token. Key NAME only here:
MEMOS_API_TOKEN=
