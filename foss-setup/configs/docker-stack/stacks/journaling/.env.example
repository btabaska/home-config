# journaling stack env — copy to .env and fill. KEY NAMES + non-secret defaults only.
# LAN/tailnet only. No cloud, no telemetry. See docs/journaling-stack-plan.md.

# Timezone (all three services)
TZ=America/New_York

# n8n reverse-proxy identity (fronted by Caddy). Editor + webhooks use this host.
N8N_HOST=n8n.tabaska.us
N8N_WEBHOOK_URL=https://n8n.tabaska.us/

# --- Inference (rig llama-swap, OpenAI-compatible; NOT raw Ollama :11434) --------
# Consumed by the journal-analyze workflow (journal-03), not by compose.
RIG_IP=192.168.10.12
LLM_BASE_URL=http://192.168.10.12:9292/v1
LLM_MODEL=dolphin-venice-24b
# One-line creative-but-VRAM-tight alt (OOMs while gaming): deckard-heretic
LLM_TEMP=0.35

# --- Secrets (minted in journal-02; vault journaling.* — MERGE never blind-assign) -
# Memos API token for n8n write-back (create-comment). Key name only here.
# MEMOS_API_TOKEN=
