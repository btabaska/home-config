# Diun — copy to .env and edit. Docs: https://crazymax.dev/diun/notif/ntfy/
# Your self-hosted ntfy server URL
DIUN_NTFY_ENDPOINT=https://ntfy.example.com

# Topic to publish update notifications to (subscribe to this in the ntfy app)
DIUN_NTFY_TOPIC=diun

# Access token if ntfy auth is enabled (create with: ntfy token add <user>)
DIUN_NTFY_TOKEN=

TZ=America/New_York
