# vaultwarden .env — copy to .env and fill in. .env is gitignored; the live
# ADMIN_TOKEN is also recorded in the operator vault (.handoff-secrets.yaml).
TZ=America/New_York
DOMAIN=https://vault.tabaska.us
# TODO: leave true only until the operator registers their account at
# https://vault.tabaska.us, then flip to false and `docker compose up -d`.
SIGNUPS_ALLOWED=true
# Generate with: openssl rand -base64 48
ADMIN_TOKEN=
