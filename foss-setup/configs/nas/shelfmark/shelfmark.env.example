# Shelfmark env — copy to shelfmark.env, fill secrets from the vault, chmod 600.
PUID=1026
PGID=100
TZ=America/New_York
SEARCH_MODE=universal
# Metadata: Hardcover primary (token from vault books.hardcover_api_token), OpenLibrary fallback
METADATA_PROVIDER=hardcover
HARDCOVER_ENABLED=true
HARDCOVER_API_KEY=          # vault: books.hardcover_api_token
INGEST_DIR=/books
# Direct Download (Anna's Archive) fallback source
DIRECT_DOWNLOAD_ENABLED=true
# Prowlarr (MAM etc.) — primary source
PROWLARR_ENABLED=true
PROWLARR_URL=http://192.168.10.4:9696
PROWLARR_API_KEY=           # vault: arr_api_keys.prowlarr
PROWLARR_USE_SEED_PREFERENCES=true
PROWLARR_TORRENT_CLIENT=deluge
PROWLARR_TORRENT_ACTION=keep
# Seedbox Deluge (same endpoint Bookshelf uses)
DELUGE_HOST=100.119.134.94
DELUGE_PORT=5945
DELUGE_PASSWORD=            # vault: deluge.password
DELUGE_CATEGORY=shelfmark
DELUGE_DOWNLOAD_DIR=/home/hd34/btabaska/files
# Non-env (persisted in /config via settings API): USE_DOH=false, AA_MIRROR_URLS,
# USING_EXTERNAL_BYPASSER=true + EXT_BYPASSER_URL=http://192.168.10.4:8191 (flaresolverr)
