# Immich .env — copy to `.env` next to docker-compose.yml and fill in real values.
# Reference: https://github.com/immich-app/immich/releases/latest/download/example.env
#            https://docs.immich.app/install/environment-variables
#
# Do NOT commit the real .env. Store DB_PASSWORD in your password manager.

# ----- Version pin -----
# REQUIRED — docker-compose.yml has no fallback (${IMMICH_VERSION:?...}); compose
# refuses to start without it, so a floating `release` deploy can't happen silently.
# Pinned to a specific release for reproducible deploys on the DS920+. The DB and
# Valkey images in docker-compose.yml are digest-pinned to match THIS release —
# re-verify them against the release compose whenever you bump this.
# To upgrade: bump this, re-read the release notes, then `docker compose pull && up -d`.
# ⚠ ALSO bump the rig remote-ML image tag in /opt/stacks/immich-ml/.env (repo mirror
#   foss-setup/configs/host/rig/immich-ml/.env.example) to the SAME version in the same
#   change — a rig -cuda / NAS server version skew breaks the ML API (nas-32). The
#   rig-immich-ml-version-match check warns on skew, but bump both to avoid it.
IMMICH_VERSION=v3.0.3

# ----- Storage locations (on the Synology Btrfs volume) -----
# UPLOAD_LOCATION holds all original photos/videos — this is Tier 1 irreplaceable data.
UPLOAD_LOCATION=/volume1/photo
# Postgres data + nightly dumps (Tier 1 via Hyper Backup + pg_dump task).
DB_DATA_LOCATION=/volume1/docker/immich/postgres

# ----- Timezone (used by some workers) -----
TZ=America/New_York

# ----- Database credentials -----
# Generate a strong password, e.g.: openssl rand -base64 36
DB_PASSWORD=CHANGE_ME_strong_db_password
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# ----- Machine-learning (glue-14: NAS iGPU is the DAYTIME fallback) -----
# The rig 3090 Ti ML container is time-gated to a night window (see
# configs/host/rig/immich-ml/), so by DAY all ML runs on this NAS OpenVINO
# container (Intel iGPU). These two vars keep interactive smart search snappy:
#   PRELOAD__CLIP__TEXTUAL — load the CLIP TEXT tower at container start so the
#     first search after a (re)start is warm (~225ms) instead of a ~27s cold load.
#     Only the text tower is preloaded — image/face models are for indexing, which
#     is paused by day and runs on the rig at night, so they stay off the NAS iGPU.
#   MODEL_TTL=86400 — keep a loaded model resident 24h instead of unloading after
#     the 300s default, so sporadic daytime searches never hit the 27s cold path.
#     RAM-cheap on the DS920+ (19GB, ~13GB free; the text tower is a few hundred MB).
# The model name MUST match the deployed CLIP model (Admin > Settings > ML).
MACHINE_LEARNING_PRELOAD__CLIP__TEXTUAL=ViT-B-16-SigLIP2__webli
MACHINE_LEARNING_MODEL_TTL=86400
