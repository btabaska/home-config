# .env.example — environment for the NAS media-automation stack (Phase 2)
#
# Usage on the DS920+ (Container Manager / SSH):
#   cp .env.example .env   &&   edit every value   &&   docker compose up -d
# Do NOT commit your filled-in .env (the stack .gitignore should ignore it).

# --- common to EVERY service (must be identical across all of them) -------------
# TODO: run `id <user>` on the NAS for the user that owns /volume1/docker AND
# /volume1/media, then paste the uid/gid here. DSM service users are often
# 1026/100, etc. Getting these wrong = permission errors on import.
PUID=1000
PGID=1000
TZ=America/New_York

# --- seedbox live mount (read by sonarr/radarr/lidarr/readarr/unpackerr) --------
# Host path of the rclone SFTP mount of seedbox:/home/hd34/btabaska/files.
# Mounted into every download-touching container at /seedbox (rslave).
# Keep in sync with scripts/media/rclone-seedbox-mount.sh.
SEEDBOX_MOUNT=/volume1/mounts/seedbox-files

# --- rreading-glasses Postgres --------------------------------------------------
RG_DB_NAME=rreading-glasses
RG_DB_USER=rreading-glasses
# Generate a random string WITHOUT special symbols (upstream guidance), e.g.:
#   openssl rand -hex 24
RG_DB_PASSWORD=<generate-a-random-alphanumeric-password>
