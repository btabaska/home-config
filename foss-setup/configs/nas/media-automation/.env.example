# .env.example — environment for the NAS media-automation stack (Phase 2)
#
# Usage on the DS920+ (Container Manager / SSH):
#   cp .env.example .env   &&   edit every value   &&   docker compose up -d
# Do NOT commit your filled-in .env (the stack .gitignore should ignore it).

# --- common to EVERY service (must be identical across all of them) -------------
# TODO: run `id <user>` on the NAS for the user that owns ${DOCKER_ROOT} and the
# library shares, then paste the uid/gid here. DSM service users are often
# 1026/100, etc. Getting these wrong = permission errors on import.
PUID=1000
PGID=1000
TZ=America/New_York

# --- three-volume library paths (../SCHEMA.md) --------------------------------
TV_LIBRARY=/volume3/tv
MOVIES_LIBRARY=/volume2/movies
MUSIC_LIBRARY=/volume1/music
DOCKER_ROOT=/volume1/docker
CWA_INGEST=/volume1/docker/calibre-web-automated/ingest
READARR_LIBRARY=/volume1/docker/readarr/library
# Whisparr (seed-13) organizes into a subfolder of the Stash library so Stash
# indexes new scenes on scan. Isolated from the hand-curated /volume1/stash/root pile.
WHISPARR_LIBRARY=/volume1/stash/root/whisparr

# --- seedbox live mount (read by sonarr/radarr/lidarr/readarr/unpackerr) --------
# Host path of the rclone SFTP mount of seedbox:/home/hd34/btabaska/files.
# Mounted into every download-touching container at /seedbox (rslave).
# Keep in sync with scripts/media/rclone-seedbox-mount.sh.
SEEDBOX_MOUNT=/volume1/mounts/seedbox-files

# --- manual lane (rclone-manual-copy.sh only — not used by compose) -------------
MANUAL_DST=/volume1/manual

# --- rreading-glasses Postgres --------------------------------------------------
RG_DB_NAME=rreading-glasses
RG_DB_USER=rreading-glasses
# Generate a random string WITHOUT special symbols (upstream guidance), e.g.:
#   openssl rand -hex 24
RG_DB_PASSWORD=<generate-a-random-alphanumeric-password>

# --- Soularr (Phase D — bridge to slskd on Betty) -------------------------------
SOULARR_INTERVAL=300

# slskd API URL is set in soularr/config.ini (use Betty Tailscale hostname).
# Example: http://betty.<tailnet>:5030
