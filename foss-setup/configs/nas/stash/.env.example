# Stash .env — copy to `.env` next to docker-compose.yml on the NAS.
# Do NOT commit the real .env.

# Pinned in docker-compose.yml (stashapp/stash:v0.31.1). Bump there to upgrade.

# Existing library tree (DSM share path)
STASH_ROOT=/volume1/stash

# Docker-side config (scrapers, plugins, config.yml) — separate from media
CONFIG_DIR=/volume1/docker/stash/config

# Host port (Caddy on mini fronts stash.<domain> → NAS:9999)
STASH_PORT=9999

TZ=America/New_York
