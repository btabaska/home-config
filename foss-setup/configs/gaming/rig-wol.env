# rig-wol.env — fleet Wake-on-LAN constants for the CachyOS rig (game-08)
#
# Committed to git: the NIC MAC is not secret (visible on the LAN). Every device
# that sends WoL magic packets reads this file; broadcast is auto-detected from
# the sender's local subnet (see wake-rig.sh).
#
# Update after enable-wol-cachyos.sh if the rig NIC or MAC changes.
RIG_MAC="50:eb:f6:b5:82:c6"
RIG_LAN_IP="192.168.10.12"   # reference only — WoL uses L2 broadcast, not IP
