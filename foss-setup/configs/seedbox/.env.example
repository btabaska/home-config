# slskd native install on Betty (Bytesized AppBox)
#
# Copy to the seedbox:
#   scp configs/seedbox/slskd-native.example.env seedbox:~/slskd-native/.env
#
# Do NOT use rootless Docker for slskd — peer port 50300 will not be reachable.
# See scripts/media/install-slskd-native.sh and configs/seedbox/music-pipeline.md.
#
# Do NOT commit your filled-in .env.

# This file is an alias — the canonical template is slskd-native.example.env
# (kept for backward compatibility with older docs that referenced .env.example).
