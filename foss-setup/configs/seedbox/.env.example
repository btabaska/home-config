# .env.example — environment for the seedbox compose templates (Phase 2)
#
# Covers BOTH:
#   - slskd-soularr-compose.example.yaml  (slskd + Soularr)
#   - unpackerr-compose.example.yaml      (Unpackerr)
#
# Usage (on the seedbox, under the plan's rootless Docker — no root needed):
#   cp .env.example .env   &&   edit every <PLACEHOLDER>   &&   docker compose up -d
#
# All values are placeholders. Do NOT commit your filled-in .env.

# --- common (all containers) ----------------------------------------------------
# Run containers as your seedbox user so files are owned correctly (id -u / id -g).
PUID=1000
PGID=1000
TZ=America/New_York

# --- slskd + Soularr ------------------------------------------------------------
# Soulseek network account (free; register in the app or at slsknet.org).
SLSKD_SLSK_USERNAME=<your-soulseek-username>
SLSKD_SLSK_PASSWORD=<your-soulseek-password>

# slskd web UI / API login. Soularr authenticates to slskd with these (or an API key).
SLSKD_WEB_USERNAME=slskd
SLSKD_WEB_PASSWORD=<choose-a-strong-slskd-web-password>

# Shared downloads dir — slskd writes here and Soularr/Lidarr read from the SAME path.
# Point at your one data tree, e.g. /home/<user>/data/downloads/slskd.
MUSIC_DOWNLOADS=/home/<user>/data/downloads/slskd

# How often (seconds) Soularr re-checks Lidarr's Wanted list and searches slskd.
SOULARR_INTERVAL=300

# --- Unpackerr ------------------------------------------------------------------
# Root of the single data tree the *arrs use (so extracted paths match what they report).
DATA_ROOT=/home/<user>/data

# Each *arr's URL + API key (Settings -> General in each app). On the seedbox the
# *arrs are reachable on localhost at their default ports.
SONARR_URL=http://localhost:8989
SONARR_API_KEY=<sonarr-api-key>

RADARR_URL=http://localhost:7878
RADARR_API_KEY=<radarr-api-key>

LIDARR_URL=http://localhost:8686
LIDARR_API_KEY=<lidarr-api-key>
