# .env.example — environment for the seedbox compose templates (Phase 2)
#
# Covers:
#   - slskd-compose.example.yaml       (slskd on Betty — current Soulseek path)
#   - slskd-soularr-compose.example.yaml  (legacy combined stack — deprecated)
#   - unpackerr-compose.example.yaml   (legacy — Unpackerr runs on NAS now)
#
# Usage (on the seedbox, under rootless Docker — no root needed):
#   cp .env.example .env   &&   edit every <PLACEHOLDER>   &&   docker compose up -d
#
# All values are placeholders. Do NOT commit your filled-in .env.

# --- common (all containers) ----------------------------------------------------
PUID=1000
PGID=1000
TZ=America/New_York

# --- slskd (Betty — Soulseek P2P off-site) --------------------------------------
# Soulseek account (free; register in the app or at slsknet.org).
SLSKD_SLSK_USERNAME=<your-soulseek-username>
SLSKD_SLSK_PASSWORD=<your-soulseek-password>

# slskd web UI / API login. Soularr on the NAS authenticates with API key (preferred).
SLSKD_WEB_USERNAME=slskd
SLSKD_WEB_PASSWORD=<choose-a-strong-slskd-web-password>

# Host path for Soulseek downloads. MUST be under ~/files/ for NAS rclone import:
#   /home/hd34/btabaska/files/slskd  →  NAS /seedbox/slskd/
SLSKD_DOWNLOADS=/home/hd34/btabaska/files/slskd

# --- Legacy slskd-soularr-compose (deprecated — Soularr now on NAS) ------------
MUSIC_DOWNLOADS=/home/hd34/btabaska/files/slskd
SOULARR_INTERVAL=300

# --- Legacy Unpackerr (Unpackerr now runs on NAS media-automation stack) --------
DATA_ROOT=/home/<user>/data
SONARR_URL=http://localhost:8989
SONARR_API_KEY=<sonarr-api-key>
RADARR_URL=http://localhost:7878
RADARR_API_KEY=<radarr-api-key>
LIDARR_URL=http://localhost:8686
LIDARR_API_KEY=<lidarr-api-key>
