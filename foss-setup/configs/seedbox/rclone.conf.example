# rclone.conf — SFTP remote template for pulling finished media from the seedbox -> NAS
# Phase 2.  This file lives on the NAS (the machine that PULLS), not the seedbox.
#
# Default location rclone looks for this file:
#   Linux/NAS:  ~/.config/rclone/rclone.conf   (check with: rclone config file)
# Copy this template there and replace every <PLACEHOLDER>. Then `chmod 600` it.
#
# Docs:
#   SFTP backend:        https://rclone.org/sftp/
#   Config file:         https://rclone.org/docs/#config-config-file
#   rclone copy:         https://rclone.org/commands/rclone_copy/
#   rclone sync:         https://rclone.org/commands/rclone_sync/
#
# TWO CONSUMERS of this `seedbox:` remote (see ../../scripts/media/):
#   1. rclone-seedbox-mount.sh  — the LIVE mount the *arrs import from
#                                 (seedbox:/home/hd34/btabaska/files -> /volume1/mounts/seedbox-files)
#   2. rclone-manual-copy.sh    — the ONE scheduled job, manual lane only
#                                 (seedbox:.../files/manual -> /volume1/manual)
# Both reference the SAME remote defined below.
#
# SECURITY: prefer key-based auth over a password. Synology Task Scheduler runs
# these as ROOT, so generate the key in root's home and reference it by ABSOLUTE
# path (a `~` here would expand to whoever runs rclone — inconsistent). Both the
# private key AND known_hosts live under /root/.ssh so the (root) run finds them:
#   sudo ssh-keygen -t ed25519 -f /root/.ssh/seedbox_ed25519 -C "nas-rclone"
#   sudo ssh-copy-id -i /root/.ssh/seedbox_ed25519.pub -p 22 btabaska@185.162.184.38
# Then point key_file at the PRIVATE key below. Do NOT also set `pass`.
#
# HOST: the seedbox "Betty" (Bytesized AppBox) is reached directly over SFTP at
# its shared IP. SFTP is encrypted, so direct is fine. (If you later put the box
# on Tailscale you may swap `host` for the 100.x.y.z / MagicDNS name.)

[seedbox]
type = sftp
# Seedbox "Betty" — Bytesized AppBox, no root, shared IP.
host = 185.162.184.38
user = btabaska
# Bytesized AppBox SSH/SFTP is on the standard port 22.
port = 22
# Key-based auth (recommended). Absolute path to the PRIVATE key on the NAS.
# TODO: generate this key on the NAS (as root) and ssh-copy-id it to the seedbox.
key_file = /root/.ssh/seedbox_ed25519
# --- Password auth alternative (NOT recommended) ----------------------------------
# Leave key_file blank and instead set an obscured password. NEVER paste a plaintext
# password here — obscure it first:  rclone obscure 'your-sftp-password'
# pass = <OUTPUT_OF_rclone_obscure>
# ----------------------------------------------------------------------------------
# Pin the host key after the first connect to defeat MITM (get it with: ssh-keyscan -p <port> <host>).
# Format: "ssh-ed25519 AAAA..."  Comma-separate multiple keys. Absolute path under
# root's home so the (root) cron run reads the same known_hosts as the key above.
known_hosts_file = /root/.ssh/known_hosts
# Disable legacy/weak algorithms; modern seedboxes support ed25519 fine.
# shell_type lets rclone use server-side features when available.
shell_type = unix
# md5sum/sha1 over SSH speed up checksum comparisons if the seedbox shell provides them.
# Leave default unless the provider's restricted shell errors on these.
# disable_hashcheck = false
