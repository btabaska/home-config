# slskd native install on Betty (Bytesized AppBox)
#
# Copy to the seedbox:
#   scp slskd-native.example.env seedbox:~/slskd-native/.env
#   ssh seedbox 'chmod 600 ~/slskd-native/.env && systemctl --user restart slskd'
#
# Do NOT commit your filled-in .env.

TZ=America/New_York

# --- Soulseek network account (slsknet.org — NOT the web UI) -------------------
SLSKD_SLSK_USERNAME=<your-soulseek-username>
SLSKD_SLSK_PASSWORD=<your-soulseek-password>

# --- Web UI / API login (http://localhost:5030 via SSH tunnel) ---------------
SLSKD_WEB_USERNAME=admin
SLSKD_WEB_PASSWORD=<choose-a-strong-password>

# --- API bind (for Soularr on NAS over Tailscale) -----------------------------
# Default in install script: 127.0.0.1 (operator SSH tunnel only).
# For Soularr (nas-29), set to Betty's Tailscale IP (e.g. 100.x.x.x) so the NAS
# can reach http://betty.<tailnet>:5030. Tailnet ACLs + API key protect access.
# SLSKD_HTTP_IP=100.x.x.x

# --- Optional: API key for Soularr (create in web UI → Options → API keys) ----
# SLSKD_API_KEY=<16-255-char-key>

# --- Downloads (must stay under ~/files/ for NAS rclone import) ---------------
SLSKD_DOWNLOADS=/home/hd34/btabaska/files/slskd
