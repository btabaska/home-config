# /etc/immich-ml-window.env — root-only (chmod 600, root:root). glue-14.
# Consumed by immich-ml-window@.service (EnvironmentFile).
#
# IMMICH_URL      — Immich server base URL. Use the LAN address so the rig->NAS
#                   call does not depend on Caddy / public DNS. (vault immich.lan_url)
# IMMICH_API_KEY  — a LEAST-PRIVILEGE Immich API key with permissions
#                   [job.create, job.read] ONLY (not admin) — enough to pause/resume
#                   the ML job queues, nothing else. (vault immich.rig_ml_window_api_key)
IMMICH_URL=http://192.168.10.4:2283
IMMICH_API_KEY=REPLACE_ME__vault_immich.rig_ml_window_api_key
