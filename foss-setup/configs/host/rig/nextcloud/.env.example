# Nextcloud eval stack env — copy to .env on the rig (chmod 600, gitignored).
# Real values live in the vault under nextcloud.* (foss-setup/.handoff-secrets.yaml):
#   DB_NAME            <- nextcloud.db_name
#   DB_USER            <- nextcloud.db_user
#   DB_PASSWORD        <- nextcloud.db_password
#   DB_ROOT_PASSWORD   <- nextcloud.db_root_password
#   REDIS_PASSWORD     <- nextcloud.redis_password
#   NEXTCLOUD_ADMIN_USER      <- nextcloud.btabaska_user (first admin, created on install)
#   NEXTCLOUD_ADMIN_PASSWORD  <- nextcloud.btabaska_password
# The second admin (Kaevis / display "Kaelyn") is created post-install via occ, not env.
DB_NAME=nextcloud
DB_USER=nextcloud
DB_PASSWORD=CHANGE_ME
DB_ROOT_PASSWORD=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME
NEXTCLOUD_ADMIN_USER=btabaska
NEXTCLOUD_ADMIN_PASSWORD=CHANGE_ME
