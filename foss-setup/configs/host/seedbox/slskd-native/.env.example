# slskd credentials — LIVE copy: seedbox ~/slskd-native/.env (chmod 600, NOT in git).
# Values live in foss-setup/.handoff-secrets.yaml (soulseek.*).
# After editing the live file: systemctl --user restart slskd
TZ=America/New_York

# Soulseek network login (slsknet.org account)
SLSKD_SLSK_USERNAME=
SLSKD_SLSK_PASSWORD=

# Web UI login (http://127.0.0.1:5030 — tailnet-only since fix-21)
SLSKD_WEB_USERNAME=
SLSKD_WEB_PASSWORD=

# Soularr API key (create in web UI → Options → API keys)
SLSKD_API_KEY=

# Download directory (must stay under ~/files/ for NAS import)
SLSKD_DOWNLOADS=/home/hd34/btabaska/files/slskd

# Web bind. MUST stay 127.0.0.1 (fix-21 lockdown): userspace tailscaled forwards
# inbound tailnet connections to loopback, so tailnet peers still reach the API at
# http://100.119.134.94:5030 while the public IP exposes nothing. Do NOT set the
# tailnet IP here — with --tun=userspace-networking there is no interface to bind.
SLSKD_HTTP_IP=127.0.0.1
